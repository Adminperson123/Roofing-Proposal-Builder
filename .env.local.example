# ── OpenAI ──────────────────────────────────────────────
# Used by /api/generate (proposal copy) and /api/proposal/[id]/chat-edit (AI editor)
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4-turbo

# ── Supabase ────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://qsfdfvgumcpoxhltrjsj.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_okI4FIcnGjxPqRTojJgxxw_BWbrB0hD
SUPABASE_SERVICE_ROLE_KEY=eyJ... (Settings -> API -> service_role)

# ── Public site URL ─────────────────────────────────────
# Used to build shareable proposal links inside emails / PDFs
NEXT_PUBLIC_SITE_URL=https://roofing-proposal-builder.vercel.app

# ── Admin auth ──────────────────────────────────────────
# Single password gate for the rep / admin dashboard.
# Set the real value in Vercel env vars only — never commit it here.
ADMIN_PASSWORD=change_me_to_a_strong_password
# Random 32+ char string used to sign auth cookies
AUTH_SECRET=change_me_to_something_random_at_least_32_chars

# ── GoHighLevel (outbound SMS / email / CRM sync) ───────
# Private Integration Token for the GHL location. The code reads GHL_PIT.
GHL_PIT=
GHL_LOCATION_ID=
# Optional — GHL custom field key the proposal link is written into (sync-ghl).
GHL_PROPOSAL_FIELD_KEY=
# Optional — name hints used to locate the pipeline + "accepted" stage on accept.
GHL_PIPELINE_NAME_HINT=proposal
GHL_ACCEPTED_STAGE_HINT=accepted

# ── Cron ────────────────────────────────────────────────
# Bearer secret Vercel Cron sends to /api/cron/followup.
CRON_SECRET=
